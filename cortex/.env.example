# Cortex 配置示例
# 复制到 ~/.cortex/.env 使用（全局配置，所有项目共用）
# 也可放置到 {cwd}/.cortex/.env 作为项目级配置（项目级覆盖全局）

# ============================================
# 搜索配置
# ============================================

# 搜索目录
# CORTEX_SEARCH_PATH=E:/github/notebook

# 索引路径（可选，默认 {search_path}/.cortex/index.db）
# CORTEX_INDEX_PATH=

# search tool 返回的最多的结果数(包含不同文档)
CORTEX_MAX_RESULTS=20

# search tool 返回的最多的结果数(同一个文档)
CORTEX_MAX_NODES_PER_DOC=5

# 搜索返回的文档数,控制 FTS5 搜索时最多返回多少个文档
CORTEX_TOP_K_DOCS=100

# 关键词最大跨度
CORTEX_MAX_SPAN=20

# 最少关键词匹配数
CORTEX_MIN_KEYWORD_MATCH=2

# 最低邻近度阈值（0/1/2，2=全部关键词紧邻）
CORTEX_MIN_PROXIMITY_SCORE=1

# 行级关键词匹配阈值（决定哪些行被选为"最佳行"）
CORTEX_MIN_KEYWORDS_PER_LINE=2

# 综合评分阈值（低于此值的搜索结果将被过滤，0.0=不过滤）
CORTEX_MIN_SCORE_THRESHOLD=0.0

# ============================================
# 终端显示配置
# ============================================

# 标题截断宽度
CORTEX_TITLE_WIDTH=55

# 单行显示宽度
CORTEX_LINE_WIDTH=78

# 上下文行数上限
CORTEX_MAX_CONTEXT_LINES=5

# 锚点行数上限（以几个最佳行为中心展开上下文）
CORTEX_MAX_ANCHOR_LINES=3

# 锚点上下文扩展范围（前后各几行）
CORTEX_CONTEXT_EXPAND_RANGE=5

# ============================================
# KB 工具字符限制（影响 LLM token 消耗）
# ============================================

# 每条搜索结果最大上下文字符数
CORTEX_MAX_CONTEXT_CHARS_PER_RESULT=800

# 搜索结果总字符数上限
CORTEX_MAX_TOTAL_CHARS=10000

# 文档读取最大返回字符数
CORTEX_MAX_READ_CHARS=6000

# ============================================
# Ripgrep 降级搜索
# ============================================

# 匹配行向上扩展行数
CORTEX_RG_CONTEXT_BEFORE=6

# 匹配行向下扩展行数
CORTEX_RG_CONTEXT_AFTER=5

# CJK 分词器 (jieba/bigram/char)
CORTEX_CJK_TOKENIZER=jieba

# ============================================
# 评分权重配置
# ============================================

# 关键词匹配权重
CORTEX_WEIGHT_KEYWORD_MATCH=3.0

# 文件名匹配权重
CORTEX_WEIGHT_FILE_NAME_MATCH=2.0

# FTS 原始分数权重
CORTEX_WEIGHT_FTS_SCORE=2.0

# 标题匹配权重
CORTEX_WEIGHT_TITLE_MATCH=1.5

# 邻近度权重（0=无匹配, 1=部分匹配, 2=全部关键词紧邻，归一化为 0/0.5/1.0）
CORTEX_WEIGHT_PROXIMITY_MATCH=1.0

# 是否为二进制文件（PDF、DOCX、XLSX、PPTX）生成 Shadow Markdown（用于 ripgrep 降级搜索）
# 关闭可加速索引构建
TREESEARCH_ENABLE_SHADOW_MD=True

# ============================================
# 日志配置
# ============================================

# 日志文件目录（默认为 .cortex/logs）
# CORTEX_LOG_DIR=C:/Users/lianghao/github/notebook/.cortex/logs

# ============================================
# 文件监控
# ============================================

# 是否启用文件监控（自动检测变化并更新索引）
CORTEX_WATCH_ENABLED=False

# 文件变化后触发 reindex 的防抖秒数
CORTEX_WATCH_DEBOUNCE=5.0

# ============================================
# Planify / Agent 配置
# ============================================

# Anthropic API 密钥（必需）
PLANIFY_BASE_URL=https://api.minimaxi.com/anthropic
PLANIFY_API_KEY=sk-ant-xxxxx
PLANIFY_MODEL_ID=MiniMax-M2.7-highspeed
